{
  "name": "@zeiq/locca",
  "version": "0.1.1",
  "description": "TUI for managing local LLM inference with llama.cpp",
  "type": "module",
  "bin": {
    "locca": "bin/locca"
  },
  "files": [
    "bin",
    "dist",
    ".claude/skills",
    "CLAUDE.md",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc",
    "dev": "tsc --watch",
    "start": "node bin/locca",
    "site": "python3 -m http.server 8765 --bind 127.0.0.1 --directory docs",
    "prepublishOnly": "npm run build",
    "release": "npm publish --access=public"
  },
  "keywords": [
    "llama.cpp",
    "llm",
    "tui",
    "cli",
    "gguf",
    "huggingface",
    "pi"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/perminder-klair/locca.git"
  },
  "dependencies": {
    "@clack/prompts": "^0.8.2",
    "@inquirer/search": "^3.0.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "typescript": "^5.6.3"
  }
}
