#!/bin/bash
# pi-llm — TUI for managing local LLM inference with llama.cpp
# Tuned for AMD Ryzen AI 9 HX 370 + Radeon 890M (Vulkan, 24GB VRAM)

set -euo pipefail

# Load user config (written by install.sh) — overrides defaults below.
PI_LLM_CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/pi-llm/config"
# shellcheck source=/dev/null
[[ -f "$PI_LLM_CONFIG" ]] && source "$PI_LLM_CONFIG"

# Auto-detect threads: nproc minus 2 (leave headroom for OS/UI), floor 1.
auto_threads() {
    local n
    n=$(nproc 2>/dev/null || echo 4)
    (( n > 2 )) && echo $((n - 2)) || echo 1
}

MODELS_DIR="${MODELS_DIR:-$HOME/.lmstudio/models}"
EXTRA_DIR="${EXTRA_DIR:-$MODELS_DIR/extra-models}"
DEFAULT_PORT="${DEFAULT_PORT:-8080}"
DEFAULT_CTX="${DEFAULT_CTX:-32768}"
DEFAULT_THREADS="${DEFAULT_THREADS:-$(auto_threads)}"
LLAMA_SERVER="${LLAMA_SERVER:-llama-server}"
LLAMA_CLI="${LLAMA_CLI:-llama-cli}"
LLAMA_BENCH="${LLAMA_BENCH:-llama-bench}"
PI_SKILL_DIR="${PI_SKILL_DIR:-$HOME/.claude/skills/agent-browser}"

RUNDIR="${XDG_RUNTIME_DIR:-/tmp}"
PIDFILE="$RUNDIR/pi-llm-server.pid"
LOGFILE="$RUNDIR/pi-llm-server.log"

require_pi() {
    if ! command -v pi >/dev/null 2>&1; then
        cat >&2 <<EOF
pi-llm: 'pi' (coding agent) not found in PATH.

The 'pi' subcommand requires the pi CLI. Install it with:
  npm install -g @mariozechner/pi-coding-agent
or via mise:
  mise use -g npm:@mariozechner/pi-coding-agent

Docs: https://pi.dev  |  Source: https://github.com/badlogic/pi-mono

If you only want serve/chat/bench, use those subcommands — they don't
need pi.
EOF
        exit 1
    fi
}

# Required only for serve/chat/pi/bench. Status/info/list don't need llama.cpp.
require_llama() {
    if ! command -v "$LLAMA_SERVER" >/dev/null 2>&1; then
        cat >&2 <<EOF
pi-llm: '$LLAMA_SERVER' not found in PATH.

Install llama.cpp by one of:
  sudo pacman -S llama.cpp                       # official Arch package
  yay -S llama.cpp-vulkan-git                    # AUR (Vulkan / Radeon)
  yay -S llama.cpp-hip-git                       # AUR (ROCm / HIP)
  build from source: https://github.com/ggml-org/llama.cpp

If you built from source, ensure llama-server/llama-cli are on \$PATH or
set LLAMA_SERVER / LLAMA_CLI in ~/.config/pi-llm/config to absolute paths.
EOF
        exit 1
    fi
}

# Per-model context override — picked by name match.
# MoE / hybrid-attention models tolerate big ctx (small per-token KV).
# Dense models hit VRAM hard above ~32k.
ctx_for_model() {
    local name="$1"
    case "$name" in
        *A3B*|*MoE*|*moe*) echo 131072 ;;
        *35B*|*32B*|*30B*) echo 65536 ;;
        *27B*|*24B*|*22B*) echo 32768 ;;
        *14B*|*13B*|*12B*) echo 65536 ;;
        *8B*|*7B*|*4B*|*3B*) echo 131072 ;;
        *) echo 32768 ;;
    esac
}

header() {
    echo ""
    gum style \
        --foreground 212 --bold \
        --border rounded --border-foreground 240 \
        --padding "0 2" \
        "pi-llm  ·  local inference"
    echo ""
}

# ── Model scanning ──

declare -a MODEL_NAMES=()
declare -a MODEL_PATHS=()
declare -a MODEL_SIZES=()
declare -a MODEL_VISION=()
declare -a MODEL_LINES=()

scan_models() {
    MODEL_NAMES=()
    MODEL_PATHS=()
    MODEL_SIZES=()
    MODEL_VISION=()
    MODEL_LINES=()

    while IFS= read -r path; do
        local name size_bytes size_gb vision_tag=""
        name=$(basename "$path" .gguf)
        size_bytes=$(stat -c%s "$path" 2>/dev/null || echo 0)
        size_gb=$(awk "BEGIN{printf \"%.1f\", $size_bytes/1024/1024/1024}")

        local dir
        dir=$(dirname "$path")
        if find "$dir" -maxdepth 1 -name "mmproj*" -name "*.gguf" 2>/dev/null | grep -q .; then
            vision_tag=" [vision]"
        fi

        MODEL_NAMES+=("$name")
        MODEL_PATHS+=("$path")
        MODEL_SIZES+=("$size_gb")
        MODEL_VISION+=("$vision_tag")
        MODEL_LINES+=("$(printf '%-48s  %6s GB%s' "$name" "$size_gb" "$vision_tag")")
    done < <(find -L "$MODELS_DIR" -name "*.gguf" ! -name "mmproj*" 2>/dev/null | sort)
}

pick_model() {
    scan_models

    if [[ ${#MODEL_NAMES[@]} -eq 0 ]]; then
        gum style --foreground 196 "No models found in $MODELS_DIR"
        exit 1
    fi

    local choice
    choice=$(printf '%s\n' "${MODEL_LINES[@]}" | gum filter --placeholder "search models..." --height 15)
    [[ -z "$choice" ]] && exit 0

    for i in "${!MODEL_LINES[@]}"; do
        if [[ "${MODEL_LINES[$i]}" == "$choice" ]]; then
            echo "${MODEL_PATHS[$i]}"
            return
        fi
    done
}

# ── Server ──

server_running() {
    if [[ -f "$PIDFILE" ]]; then
        local pid
        pid=$(cat "$PIDFILE")
        if kill -0 "$pid" 2>/dev/null; then
            return 0
        else
            rm -f "$PIDFILE"
        fi
    fi
    return 1
}

server_status() {
    if server_running; then
        local pid model_name port
        pid=$(cat "$PIDFILE")
        model_name=$(ps -p "$pid" -o args= 2>/dev/null | grep -oP '(?<=--model ).*?\.gguf' | xargs basename 2>/dev/null || echo "unknown")
        port=$(ps -p "$pid" -o args= 2>/dev/null | grep -oP '(?<=--port )\d+' || echo "$DEFAULT_PORT")
        gum style --foreground 78 "● Running: ${model_name} (port ${port}, pid ${pid})"
    else
        gum style --foreground 240 "○ No server running"
    fi
}

do_serve() {
    require_llama
    if server_running; then
        local pid
        pid=$(cat "$PIDFILE")
        gum style --foreground 214 "Server already running (pid ${pid})"
        if gum confirm "Stop it and start a new one?"; then
            kill "$pid" 2>/dev/null
            sleep 1
            rm -f "$PIDFILE"
        else
            return
        fi
    fi

    local model_path
    model_path=$(pick_model)
    [[ -z "$model_path" ]] && return

    local model_name model_dir mmproj_args=""
    model_name=$(basename "$model_path" .gguf)
    model_dir=$(dirname "$model_path")

    local mmproj=""
    mmproj=$(find "$model_dir" -maxdepth 1 -name "mmproj*" -name "*.gguf" 2>/dev/null | head -1)
    [[ -n "$mmproj" ]] && mmproj_args="--mmproj $mmproj --image-min-tokens 1024"

    local port=$DEFAULT_PORT ctx=$DEFAULT_CTX threads=$DEFAULT_THREADS
    local use_defaults
    use_defaults=$(gum choose "Default (port ${DEFAULT_PORT}, ctx ${DEFAULT_CTX})" "Custom")

    if [[ "$use_defaults" == "Custom" ]]; then
        port=$(gum input --placeholder "$DEFAULT_PORT" --header "Port" --width 20)
        port=${port:-$DEFAULT_PORT}
        ctx=$(gum input --placeholder "$DEFAULT_CTX" --header "Context size" --width 20)
        ctx=${ctx:-$DEFAULT_CTX}
        threads=$(gum input --placeholder "$DEFAULT_THREADS" --header "Threads" --width 20)
        threads=${threads:-$DEFAULT_THREADS}
    fi

    echo ""
    gum style --foreground 212 --bold "Starting server..."
    echo "  Model:   $model_name"
    echo "  Port:    $port"
    echo "  Context: $ctx"
    echo "  GPU:     Vulkan (all layers)"
    [[ -n "$mmproj" ]] && echo "  Vision:  $(basename "$mmproj")"
    echo ""

    $LLAMA_SERVER \
        --model "$model_path" \
        $mmproj_args \
        --host 0.0.0.0 \
        --port "$port" \
        --threads "$threads" \
        --n-gpu-layers 999 \
        --flash-attn on \
        --cache-type-k q8_0 \
        --cache-type-v q8_0 \
        --parallel 1 \
        --cache-reuse 256 \
        --jinja \
        --ctx-size "$ctx" &

    local pid=$!
    echo "$pid" > "$PIDFILE"

    local ready=0
    for _ in $(seq 1 60); do
        if ! kill -0 "$pid" 2>/dev/null; then
            break
        fi
        if curl -sf "http://127.0.0.1:${port}/v1/models" > /dev/null 2>&1; then
            ready=1
            break
        fi
        sleep 1
    done

    if [[ $ready -eq 1 ]]; then
        echo ""
        gum style --foreground 78 --bold "Server running on http://0.0.0.0:${port}/v1"
        echo "PID: ${pid}  |  Stop with: pi-llm stop  |  Logs: pi-llm logs"
    else
        rm -f "$PIDFILE"
        gum style --foreground 196 "Server failed to start or never became ready. Check output above."
    fi
}

do_chat() {
    require_llama
    local model_path
    model_path=$(pick_model)
    [[ -z "$model_path" ]] && return

    local model_name model_dir mmproj_args=""
    model_name=$(basename "$model_path" .gguf)
    model_dir=$(dirname "$model_path")

    local mmproj=""
    mmproj=$(find "$model_dir" -maxdepth 1 -name "mmproj*" -name "*.gguf" 2>/dev/null | head -1)
    [[ -n "$mmproj" ]] && mmproj_args="--mmproj $mmproj --image-min-tokens 1024"

    echo ""
    gum style --foreground 212 "Starting chat with $model_name..."
    echo ""

    exec $LLAMA_CLI \
        -m "$model_path" \
        $mmproj_args \
        -ngl 999 \
        -t "$DEFAULT_THREADS" \
        --flash-attn on \
        --cache-type-k q8_0 \
        --cache-type-v q8_0 \
        --jinja \
        --ctx-size "$DEFAULT_CTX" \
        -cnv
}

do_switch() {
    if server_running; then
        kill "$(cat "$PIDFILE")" 2>/dev/null
        sleep 1
        rm -f "$PIDFILE"
    fi
    do_pi "$@"
}

do_logs() {
    if [[ ! -s "$LOGFILE" ]]; then
        gum style --foreground 240 "No log at $LOGFILE (only servers started via 'pi-llm pi' write here)."
        return
    fi
    gum style --foreground 212 "Tailing $LOGFILE  (Ctrl-C to stop)"
    echo ""
    exec tail -n 50 -f "$LOGFILE"
}

do_stop() {
    if server_running; then
        local pid
        pid=$(cat "$PIDFILE")
        kill "$pid" 2>/dev/null
        rm -f "$PIDFILE"
        gum style --foreground 78 "Server stopped (pid ${pid})"
    else
        gum style --foreground 240 "No server running"
    fi
}

do_status() {
    header
    server_status
    echo ""

    scan_models

    if [[ ${#MODEL_NAMES[@]} -eq 0 ]]; then
        echo "  No models found."
        return
    fi

    gum style --foreground 212 --bold "Models (${#MODEL_NAMES[@]})"
    echo ""
    printf '%s\n' "${MODEL_LINES[@]}"
}

do_bench() {
    if ! command -v "$LLAMA_BENCH" >/dev/null 2>&1; then
        gum style --foreground 196 \
            "'$LLAMA_BENCH' not found. Set LLAMA_BENCH in $PI_LLM_CONFIG to an absolute path, or install llama.cpp's bench tool."
        return 1
    fi
    local model_path
    model_path=$(pick_model)
    [[ -z "$model_path" ]] && return

    local model_name
    model_name=$(basename "$model_path" .gguf)
    local out
    out=$(mktemp)

    echo ""
    gum style --foreground 212 "Benchmarking $model_name..."
    echo ""

    gum spin --spinner dot --title "Running llama-bench..." -- \
        bash -c "$LLAMA_BENCH -m '$model_path' -ngl 999 -t $DEFAULT_THREADS 2>&1 | grep -E '^\|' > '$out'"

    echo ""
    cat "$out"
    rm -f "$out"
}

# ── Model management ──

# Resolve a HuggingFace repo identifier from URL or name
# Input:  https://huggingface.co/user/repo  OR  user/repo
# Output: user/repo
parse_hf_repo() {
    local input="$1"
    # Strip trailing slash
    input="${input%/}"
    # If it's a URL, extract user/repo
    if [[ "$input" == https://huggingface.co/* ]]; then
        echo "$input" | sed 's|https://huggingface.co/||'
    else
        echo "$input"
    fi
}

do_download() {
    local repo=""

    # Accept repo as argument or prompt for it
    if [[ -n "${1:-}" ]]; then
        repo=$(parse_hf_repo "$1")
    else
        local input
        input=$(gum input --placeholder "user/repo or HuggingFace URL" --header "HuggingFace model" --width 60)
        [[ -z "$input" ]] && return
        repo=$(parse_hf_repo "$input")
    fi

    echo ""
    gum style --foreground 212 "Fetching files from $repo..."

    # List GGUF files via HF API
    local api_url="https://huggingface.co/api/models/${repo}"
    local files_json
    files_json=$(curl -sf "$api_url" | jq -r '.siblings[]?.rfilename // empty' 2>/dev/null)

    if [[ -z "$files_json" ]]; then
        gum style --foreground 196 "Could not fetch model info. Check the repo name."
        return
    fi

    # Filter for GGUF model files (not mmproj)
    local -a gguf_files=()
    local -a gguf_display=()
    while IFS= read -r f; do
        [[ -z "$f" ]] && continue
        gguf_files+=("$f")
        # Get size from API
        local size
        size=$(curl -sfI "https://huggingface.co/${repo}/resolve/main/${f}" 2>/dev/null | grep -i content-length | tail -1 | awk '{print $2}' | tr -d '\r')
        local size_display="?"
        if [[ -n "$size" && "$size" =~ ^[0-9]+$ ]]; then
            size_display=$(awk "BEGIN{printf \"%.1f GB\", $size/1024/1024/1024}")
        fi
        gguf_display+=("$(printf '%-60s  %s' "$f" "$size_display")")
    done < <(echo "$files_json" | grep '\.gguf$' | grep -v 'mmproj' | sort)

    if [[ ${#gguf_files[@]} -eq 0 ]]; then
        gum style --foreground 196 "No GGUF files found in $repo"
        return
    fi

    # Check for mmproj
    local mmproj_file=""
    mmproj_file=$(echo "$files_json" | grep 'mmproj.*\.gguf$' | head -1)

    if [[ -n "$mmproj_file" ]]; then
        gum style --foreground 78 "Vision projector available: $mmproj_file"
        echo ""
    fi

    # Pick a quant
    gum style --foreground 212 --bold "Select quantization"
    echo ""
    local choice
    choice=$(printf '%s\n' "${gguf_display[@]}" | gum filter --placeholder "search quants..." --height 15)
    [[ -z "$choice" ]] && return

    # Find the matching filename
    local selected_file=""
    for i in "${!gguf_display[@]}"; do
        if [[ "${gguf_display[$i]}" == "$choice" ]]; then
            selected_file="${gguf_files[$i]}"
            break
        fi
    done

    [[ -z "$selected_file" ]] && return

    # Create directory from repo name
    local repo_name
    repo_name=$(basename "$repo")
    local dest_dir="${EXTRA_DIR}/${repo_name}"
    mkdir -p "$dest_dir"

    echo ""
    gum style --foreground 212 --bold "Downloading..."
    echo "  File: $selected_file"
    echo "  To:   $dest_dir/"
    echo ""

    # Download model
    curl -L --progress-bar \
        -o "${dest_dir}/${selected_file}" \
        "https://huggingface.co/${repo}/resolve/main/${selected_file}"

    # Download mmproj if available
    if [[ -n "$mmproj_file" ]]; then
        if gum confirm "Download vision projector too?"; then
            curl -L --progress-bar \
                -o "${dest_dir}/${mmproj_file}" \
                "https://huggingface.co/${repo}/resolve/main/${mmproj_file}"
        fi
    fi

    echo ""
    gum style --foreground 78 --bold "Download complete"
    ls -lh "$dest_dir/"
}

do_delete() {
    scan_models

    if [[ ${#MODEL_NAMES[@]} -eq 0 ]]; then
        gum style --foreground 240 "No models to delete."
        return
    fi

    gum style --foreground 212 --bold "Select model to delete"
    echo ""

    local choice
    choice=$(printf '%s\n' "${MODEL_LINES[@]}" | gum filter --placeholder "search models..." --height 15)
    [[ -z "$choice" ]] && return

    local selected_path="" selected_name=""
    for i in "${!MODEL_LINES[@]}"; do
        if [[ "${MODEL_LINES[$i]}" == "$choice" ]]; then
            selected_path="${MODEL_PATHS[$i]}"
            selected_name="${MODEL_NAMES[$i]}"
            break
        fi
    done

    [[ -z "$selected_path" ]] && return

    local model_dir
    model_dir=$(dirname "$selected_path")

    echo ""
    echo "Directory: $model_dir"
    ls -lh "$model_dir/"
    echo ""

    if gum confirm --default=no "Delete $selected_name and its directory?"; then
        rm -rf "$model_dir"
        gum style --foreground 78 "Deleted: $selected_name"
    else
        gum style --foreground 240 "Cancelled."
    fi
}

do_search() {
    local query=""

    if [[ -n "${1:-}" ]]; then
        query="$1"
    else
        query=$(gum input --placeholder "e.g. gemma uncensored gguf" --header "Search HuggingFace" --width 60)
        [[ -z "$query" ]] && return
    fi

    echo ""
    gum style --foreground 212 "Searching for '$query'..."
    echo ""

    # Search HF API for GGUF models
    local results
    results=$(curl -sf "https://huggingface.co/api/models?search=${query// /+}&filter=gguf&sort=downloads&direction=-1&limit=15" 2>/dev/null)

    if [[ -z "$results" || "$results" == "[]" ]]; then
        gum style --foreground 240 "No results found."
        return
    fi

    local -a repo_ids=()
    local -a display_lines=()

    while IFS='|' read -r id downloads likes; do
        repo_ids+=("$id")
        display_lines+=("$(printf '%-55s  ↓%-8s  ♥ %s' "$id" "$downloads" "$likes")")
    done < <(echo "$results" | jq -r '.[] | "\(.id)|\(.downloads // 0)|\(.likes // 0)"' 2>/dev/null)

    if [[ ${#repo_ids[@]} -eq 0 ]]; then
        gum style --foreground 240 "No results found."
        return
    fi

    local choice
    choice=$(printf '%s\n' "${display_lines[@]}" | gum filter --placeholder "pick a model..." --height 15)
    [[ -z "$choice" ]] && return

    for i in "${!display_lines[@]}"; do
        if [[ "${display_lines[$i]}" == "$choice" ]]; then
            do_download "${repo_ids[$i]}"
            return
        fi
    done
}

do_pi() {
    require_pi
    require_llama
    local model_path=""

    # Accept model name as argument or pick interactively
    if [[ -n "${1:-}" ]]; then
        model_path=$(find -L "$MODELS_DIR" -name "*${1}*" -name "*.gguf" ! -name "mmproj*" 2>/dev/null | head -1)
        if [[ -z "$model_path" ]]; then
            gum style --foreground 196 "No model matching '$1'"
            return 1
        fi
        shift
    else
        model_path=$(pick_model)
        [[ -z "$model_path" ]] && return
    fi

    local model_id model_name model_dir
    model_id=$(basename "$model_path")
    model_name=$(basename "$model_path" .gguf)
    model_dir=$(dirname "$model_path")

    local mmproj_args=""
    local mmproj=""
    mmproj=$(find "$model_dir" -maxdepth 1 -name "mmproj*" -name "*.gguf" 2>/dev/null | head -1)
    [[ -n "$mmproj" ]] && mmproj_args="--mmproj $mmproj --image-min-tokens 1024"

    # Check if server is already running with this model
    if server_running; then
        local current
        current=$(ps -p "$(cat "$PIDFILE")" -o args= 2>/dev/null | grep -oP '(?<=--model ).*?\.gguf' | xargs basename 2>/dev/null || echo "")
        if [[ "$current" == "$model_id" ]]; then
            echo "Server already running with $model_name"
        else
            echo "Switching model: $current -> $model_name"
            kill "$(cat "$PIDFILE")" 2>/dev/null
            sleep 1
            rm -f "$PIDFILE"
        fi
    fi

    # Start server if needed — context auto-tuned per model (see ctx_for_model)
    local pi_ctx
    pi_ctx=$(ctx_for_model "$model_name")
    if ! server_running; then
        echo "Starting $model_name on port $DEFAULT_PORT (ctx $pi_ctx)..."
        $LLAMA_SERVER \
            --model "$model_path" \
            $mmproj_args \
            --host 127.0.0.1 \
            --port "$DEFAULT_PORT" \
            --threads "$DEFAULT_THREADS" \
            --n-gpu-layers 999 \
            --flash-attn on \
            --cache-type-k q8_0 \
            --cache-type-v q8_0 \
            --parallel 1 \
            --cache-reuse 256 \
            --jinja \
            --ctx-size "$pi_ctx" \
            > "$LOGFILE" 2>&1 &

        echo "$!" > "$PIDFILE"

        for _ in $(seq 1 30); do
            if curl -sf "http://127.0.0.1:${DEFAULT_PORT}/v1/models" > /dev/null 2>&1; then
                echo "Server ready."
                break
            fi
            sleep 1
        done

        if ! curl -sf "http://127.0.0.1:${DEFAULT_PORT}/v1/models" > /dev/null 2>&1; then
            gum style --foreground 196 "Server failed to start. Check $LOGFILE"
            rm -f "$PIDFILE"
            return 1
        fi
    fi

    echo "Launching pi with $model_name..."
    echo ""

    local skill_args=()
    [[ -d "$PI_SKILL_DIR" ]] && skill_args=(--skill "$PI_SKILL_DIR")

    exec pi --provider llamacpp --model "$model_id" \
        --no-skills --no-extensions \
        "${skill_args[@]}" \
        "$@"
}

do_info() {
    local model_path
    model_path=$(pick_model)
    [[ -z "$model_path" ]] && return

    local model_name model_dir
    model_name=$(basename "$model_path" .gguf)
    model_dir=$(dirname "$model_path")

    echo ""
    gum style --foreground 212 --bold "$model_name"
    echo ""

    # Basic file info
    local size_bytes size_gb
    size_bytes=$(stat -c%s "$model_path")
    size_gb=$(awk "BEGIN{printf \"%.1f\", $size_bytes/1024/1024/1024}")
    echo "  Path:  $model_path"
    echo "  Size:  ${size_gb} GB"

    # GGUF metadata via python
    python3 -c "
import struct, sys

with open('$model_path', 'rb') as f:
    magic = f.read(4)
    ver = struct.unpack('<I', f.read(4))[0]
    n_tensors = struct.unpack('<Q', f.read(8))[0]
    n_kv = struct.unpack('<Q', f.read(8))[0]
    print(f'  GGUF:  v{ver}  ({n_tensors} tensors, {n_kv} metadata)')
" 2>/dev/null

    # Check for vision projector
    local mmproj
    mmproj=$(find "$model_dir" -maxdepth 1 -name "mmproj*" -name "*.gguf" 2>/dev/null | head -1)
    if [[ -n "$mmproj" ]]; then
        local mm_size
        mm_size=$(stat -c%s "$mmproj" | awk '{printf "%.0f", $1/1024/1024}')
        echo "  Vision: $(basename "$mmproj") (${mm_size} MB)"
    else
        echo "  Vision: no"
    fi

    # Files in directory
    echo ""
    echo "  Files:"
    ls -lh "$model_dir/" | tail -n+2 | sed 's/^/    /'
}

# ── Main ──

case "${1:-}" in
    serve|start)    shift; do_serve "$@"; exit ;;
    chat)           shift; do_chat "$@"; exit ;;
    pi)             shift; do_pi "$@"; exit ;;
    switch|swap)    shift; do_switch "$@"; exit ;;
    stop)           shift; do_stop; exit ;;
    status|ls)      shift; do_status; exit ;;
    logs|log)       shift; do_logs; exit ;;
    bench)          shift; do_bench; exit ;;
    download|pull)  shift; do_download "$@"; exit ;;
    delete|rm)      shift; do_delete; exit ;;
    search|find)    shift; do_search "$@"; exit ;;
    info)           shift; do_info; exit ;;
    help|-h|--help)
        echo "Usage: pi-llm [command]"
        echo ""
        echo "Inference:"
        echo "  serve       Start API server with a model"
        echo "  chat        Interactive terminal chat"
        echo "  pi          Launch pi coding agent with a local model"
        echo "  switch      Stop current server and start a new model with pi"
        echo "  stop        Stop running server"
        echo "  bench       Benchmark a model"
        echo ""
        echo "  logs        Tail llama-server log (pi-started servers)"
        echo ""
        echo "Models:"
        echo "  status      Show models and server status"
        echo "  info        Show model details"
        echo "  download    Download model from HuggingFace"
        echo "  search      Search HuggingFace for GGUF models"
        echo "  delete      Delete a model"
        echo ""
